# --- Database ---
POSTGRES_USER=agentkobi
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agentkobi
DATABASE_URL=postgresql+asyncpg://agentkobi:changeme@postgres:5432/agentkobi

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- LLM ---
# Brifing üretimi: önce GROQ denenir, başarısız olursa GEMINI'ye düşer,
# o da fail olursa deterministik template ile devam edilir.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=

# --- WhatsApp Cloud API ---
WHATSAPP_PHONE_NUMBER_ID=
